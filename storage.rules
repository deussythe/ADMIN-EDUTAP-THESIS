rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        ).data.role is string
        && lower(
          firestore.get(
            /databases/(default)/documents/users/$(request.auth.uid)
          ).data.role
        ) == "admin";
    }

    match /branding/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
